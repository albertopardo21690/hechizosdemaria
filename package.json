{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare:tinymce": "mkdir -p public/vendor && cp -R node_modules/tinymce public/vendor/",
        "postinstall": "npm run prepare:tinymce",
        "build": "npm run prepare:tinymce && vite build",
        "dev": "npm run prepare:tinymce && vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "sortablejs": "^1.15.7",
        "tinymce": "^6.8.6"
    }
}
